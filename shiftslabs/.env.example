# Supabase Database URLs
# Get these from your Supabase project dashboard
AUTH_DATABASE_URL=postgresql://[user]:[password]@[host]/shiftslabs_auth_db?sslmode=require
CHATBOT_DATABASE_URL=postgresql://[user]:[password]@[host]/shiftslabs_chatbot_db?sslmode=require
LEARNX_DATABASE_URL=postgresql://[user]:[password]@[host]/shiftslabs_learnx_db?sslmode=require
CLASSROOM_DATABASE_URL=postgresql://[user]:[password]@[host]/shiftslabs_classroom_db?sslmode=require

# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Auth Server URL (for Account app)
AUTH_SERVER_URL=https://account.shiftslabs.com

# App URLs
CHATBOT_URL=https://chatbot.shiftslabs.com
LEARNX_URL=https://learnx.shiftslabs.com
CLASSROOM_URL=https://classroom.shiftslabs.com

# Cloudflare
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token